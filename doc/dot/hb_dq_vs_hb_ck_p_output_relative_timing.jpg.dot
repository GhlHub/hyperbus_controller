digraph hb_dq_vs_hb_ck_p_output_relative_timing {
  graph [
    rankdir=LR,
    splines=ortho,
    nodesep=0.45,
    ranksep=0.7,
    pad=0.2,
    bgcolor="white",
    label="HB_DQ vs HB_CK_P Relative Output Timing (Implemented Design)",
    labelloc=t,
    fontsize=20,
    fontname="Helvetica-Bold"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=12,
    color="#3A3A3A",
    penwidth=1.2,
    margin="0.14,0.08"
  ];

  edge [
    color="#4A4A4A",
    penwidth=1.4,
    arrowsize=0.8
  ];

  ck_min [label="hb_ck_p earliest edge\n0.494 ns", fillcolor="#FFE2C7"];
  dq_min [label="hb_dq earliest edge\n0.701 ns", fillcolor="#CFE6FF"];
  ck_max [label="hb_ck_p latest edge\n1.162 ns", fillcolor="#FFC487"];
  dq_max [label="hb_dq latest edge\n1.679 ns", fillcolor="#9DCCFF"];

  ck_min -> dq_min [label="DQ trails earliest CK by 0.207 ns"];
  dq_min -> ck_max [label="span to latest CK = 0.461 ns"];
  ck_max -> dq_max [label="DQ trails latest CK by 0.517 ns"];

  note [shape=note, fillcolor="#FFF8CC",
        label="Full relative output window:\n- DQ leads CK by up to 0.461 ns\n- DQ lags CK by up to 1.185 ns\n\nThese values are retained from the last implemented timing extraction\nand summarize the relative pin-level launch skew."];

  dq_max -> note [style=dashed, arrowhead=none];
}
