              "registers": {
                "TX_BYTE_FIFO": {
                  "address_offset": "0x000",
                  "size": 32,
                  "display_name": "Transmit Byte Register",
                  "description": "Write one byte to the transmit FIFO. Readback returns the last written byte value.",
                  "access": "read-write",
                  "fields": {
                    "TX_BYTE": {
                      "bit_offset": 0,
                      "bit_width": 8,
                      "description": "Transmit byte value",
                      "access": "read-write"
                    }
                  }
                },
                "TX_WORD_FIFO": {
                  "address_offset": "0x004",
                  "size": 32,
                  "display_name": "Transmit Word Register",
                  "description": "Write four bytes to the transmit FIFO. Byte 0 is transmitted first.",
                  "access": "read-write",
                  "fields": {
                    "TX_WORD": {
                      "bit_offset": 0,
                      "bit_width": 32,
                      "description": "Transmit word value",
                      "access": "read-write"
                    }
                  }
                },
                "RX_BYTE_FIFO": {
                  "address_offset": "0x008",
                  "size": 32,
                  "display_name": "Receive Byte Register",
                  "description": "Read one byte from the receive FIFO.",
                  "access": "read-only",
                  "fields": {
                    "RX_BYTE": {
                      "bit_offset": 0,
                      "bit_width": 8,
                      "description": "Receive byte value",
                      "access": "read-only"
                    }
                  }
                },
                "RX_WORD_FIFO": {
                  "address_offset": "0x00C",
                  "size": 32,
                  "display_name": "Receive Word Register",
                  "description": "Read four bytes from the receive FIFO. Byte 0 is returned in bits 7:0.",
                  "access": "read-only",
                  "fields": {
                    "RX_WORD": {
                      "bit_offset": 0,
                      "bit_width": 32,
                      "description": "Receive word value",
                      "access": "read-only"
                    }
                  }
                },
                "INT_STATUS": {
                  "address_offset": "0x010",
                  "size": 32,
                  "display_name": "Interrupt Status Register",
                  "description": "Current interrupt status bits. RX_TIME_COALESCE is write-1-to-clear.",
                  "access": "read-write",
                  "fields": {
                    "TX_EMPTY": {
                      "bit_offset": 0,
                      "bit_width": 1,
                      "description": "Transmit FIFO empty interrupt status",
                      "access": "read-only"
                    },
                    "TX_FIFO_ALMOST_EMPTY": {
                      "bit_offset": 1,
                      "bit_width": 1,
                      "description": "Transmit FIFO almost empty interrupt status",
                      "access": "read-only"
                    },
                    "RX_FIFO_NOT_EMPTY": {
                      "bit_offset": 2,
                      "bit_width": 1,
                      "description": "Receive FIFO not empty interrupt status",
                      "access": "read-only"
                    },
                    "RX_BYTE_THRESHOLD": {
                      "bit_offset": 3,
                      "bit_width": 1,
                      "description": "Receive FIFO byte threshold interrupt status",
                      "access": "read-only"
                    },
                    "RX_TIME_COALESCE": {
                      "bit_offset": 4,
                      "bit_width": 1,
                      "description": "Receive timeout coalescing interrupt status. Write 1 to clear.",
                      "access": "read-write"
                    }
                  }
                },
                "INT_MASK": {
                  "address_offset": "0x014",
                  "size": 32,
                  "display_name": "Interrupt Mask Register",
                  "description": "Interrupt mask bits corresponding to INT_STATUS.",
                  "access": "read-write",
                  "fields": {
                    "TX_EMPTY_MASK": {
                      "bit_offset": 0,
                      "bit_width": 1,
                      "description": "Mask for transmit FIFO empty interrupt",
                      "access": "read-write"
                    },
                    "TX_FIFO_ALMOST_EMPTY_MASK": {
                      "bit_offset": 1,
                      "bit_width": 1,
                      "description": "Mask for transmit FIFO almost empty interrupt",
                      "access": "read-write"
                    },
                    "RX_FIFO_NOT_EMPTY_MASK": {
                      "bit_offset": 2,
                      "bit_width": 1,
                      "description": "Mask for receive FIFO not empty interrupt",
                      "access": "read-write"
                    },
                    "RX_BYTE_THRESHOLD_MASK": {
                      "bit_offset": 3,
                      "bit_width": 1,
                      "description": "Mask for receive FIFO byte threshold interrupt",
                      "access": "read-write"
                    },
                    "RX_TIME_COALESCE_MASK": {
                      "bit_offset": 4,
                      "bit_width": 1,
                      "description": "Mask for receive timeout coalescing interrupt",
                      "access": "read-write"
                    }
                  }
                },
                "CTRL_STATUS": {
                  "address_offset": "0x018",
                  "size": 32,
                  "display_name": "Config / Status Register",
                  "description": "Control bits for TX/RX enable and current interrupt pin status.",
                  "access": "read-write",
                  "fields": {
                    "TX_EN": {
                      "bit_offset": 0,
                      "bit_width": 1,
                      "description": "Transmit enable",
                      "access": "read-write"
                    },
                    "RX_EN": {
                      "bit_offset": 1,
                      "bit_width": 1,
                      "description": "Receive enable",
                      "access": "read-write"
                    },
                    "IRQ_PIN": {
                      "bit_offset": 31,
                      "bit_width": 1,
                      "description": "Current interrupt pin state",
                      "access": "read-only"
                    }
                  }
                },
                "BAUDRATE_COUNTER": {
                  "address_offset": "0x020",
                  "size": 32,
                  "display_name": "Baud Rate Counter Register",
                  "description": "Transmit baud rate divisor in AXI clock cycles minus one.",
                  "access": "read-write",
                  "fields": {
                    "TX_BAUD_DIVISOR": {
                      "bit_offset": 0,
                      "bit_width": 13,
                      "description": "Transmit baud divisor",
                      "access": "read-write"
                    }
                  }
                },
                "OVERSAMPLE_COUNTER": {
                  "address_offset": "0x024",
                  "size": 32,
                  "display_name": "Oversample Rate Counter Register",
                  "description": "Receive oversample divisor for the 5x receiver sampling clock.",
                  "access": "read-write",
                  "fields": {
                    "RX_OVERSAMPLE_DIVISOR": {
                      "bit_offset": 0,
                      "bit_width": 10,
                      "description": "Receive oversample divisor",
                      "access": "read-write"
                    }
                  }
                },
                "INT_HOLDOFF": {
                  "address_offset": "0x028",
                  "size": 32,
                  "display_name": "Interrupt Holdoff Register",
                  "description": "RX interrupt coalescing thresholds. Program coherently with the transmit baud divisor so TX and RX operate at the same effective baud rate.",
                  "access": "read-write",
                  "fields": {
                    "RX_BYTE_TIME_COALESCE_COUNT": {
                      "bit_offset": 0,
                      "bit_width": 11,
